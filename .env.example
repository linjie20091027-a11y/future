# ========== QQ邮箱配置 ==========
# 发送方QQ邮箱地址
SENDER_EMAIL=your_qq_number@qq.com
# QQ邮箱SMTP授权码（非QQ密码！）
# 获取方式：QQ邮箱 -> 设置 -> 账户 -> POP3/SMTP服务 -> 开启 -> 生成授权码
SMTP_AUTH_CODE=your_smtp_auth_code

# 接收方邮箱（可以和发送方相同）
RECEIVER_EMAIL=your_qq_number@qq.com

# ========== 推送配置 ==========
# 推送间隔（小时），例如 3 表示每3小时推送一次
PUSH_INTERVAL_HOURS=3

# 每个源最多抓取的新闻条数（避免邮件过长）
MAX_ARTICLES_PER_SOURCE=8

# ========== RSS源配置 ==========
# 科技类RSS源（逗号分隔，名称:URL 格式）
# 内置默认源：36氪、少数派、IT之家
# TECH_RSS_URLS=36氪:https://36kr.com/feed,少数派:https://sspai.com/feed,IT之家:https://www.ithome.com/rss/

# 金融类RSS源（逗号分隔，名称:URL 格式）
# 内置默认源：FT中文网、雪球热门
# FINANCE_RSS_URLS=FT中文网:https://www.ftchinese.com/rss/news,雪球热门:https://xueqiu.com/hots/topic/rss
